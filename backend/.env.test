# Test Environment Configuration
NODE_ENV=test
PORT=5001

# MongoDB Test Database
MONGODB_URI=mongodb://localhost:27017/skill-tracker-test
DB_NAME=skill-tracker-test

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Better Auth (Test credentials)
BETTER_AUTH_SECRET=test-secret-key-for-testing-only-min-32-chars
BETTER_AUTH_URL=http://localhost:5001

# Gemini API (Use a test key or mock)
GEMINI_API_KEY=test-api-key
GEMINI_MODEL=gemini-2.5-flash

# Redis (Test configuration)
REDIS_HOST=localhost
REDIS_PORT=6379

# Email Configuration (Optional - for notification tests)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=test@example.com
SMTP_PASS=test-password
EMAIL_FROM="SkillTracker Test" <test@skilltracker.ai>
